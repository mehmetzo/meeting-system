version: '3.8'

services:
  web:
    build: .
    container_name: hastane_meeting_web
    ports:
      - "6767:80"
    volumes:
      - ./html:/var/www/html
      - ./apache/000-default.conf:/etc/apache2/sites-enabled/000-default.conf
      - ./php/php.ini:/usr/local/etc/php/conf.d/custom.ini
    depends_on:
      - db
    networks:
      - meeting_net
    environment:
      - DB_HOST=db
      - DB_PORT=3306
      - DB_NAME=meeting_db
      - DB_USER=meeting_user
      - DB_PASS=Meeting@2024!
    restart: unless-stopped

  db:
    image: mysql:8.0
    container_name: hastane_meeting_db
    ports:
      - "3310:3306"
    environment:
      MYSQL_ROOT_PASSWORD: Root@2024!
      MYSQL_DATABASE: meeting_db
      MYSQL_USER: meeting_user
      MYSQL_PASSWORD: Meeting@2024!
    volumes:
      - db_data:/var/lib/mysql
      - ./sql/init.sql:/docker-entrypoint-initdb.d/init.sql
    networks:
      - meeting_net
    restart: unless-stopped
    command: --default-authentication-plugin=mysql_native_password
              --character-set-server=utf8mb4
              --collation-server=utf8mb4_unicode_ci

networks:
  meeting_net:
    driver: bridge

volumes:
  db_data:
